NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Local Docker Postgres default from docker-compose.yml.
DATABASE_URL=postgresql://vibe_plan:vibe_plan@localhost:5432/vibe_plan

# AI provider can be "deepseek" or "openai".
AI_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=

OPENAI_MODEL=gpt-5-mini
OPENAI_API_KEY=
